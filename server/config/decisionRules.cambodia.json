{
  "__comments": {
    "path": "Its a fhir path, for syntax refer to https://www.hl7.org/fhir/fhirpath.html",
    "matchingType": "Must be specified, it can either",
    "threshold": {
      "levenshtein": "Lower the number, the closer the match, 0 being exact match, max threshold is 2",
      "jaro-winkler": "number between 0 and 1, where 0 for no match and 1 for exact match"
    },
    "supported_algorithms": {
      "elasticsearch": [
        "https://github.com/intrahealth/similarity-scoring"
      ]
    },
    "cambodia_notes": "PMRS Khmer-only import profile. Jan-1 DOB placeholders are omitted at import. Activate by replacing decisionRules.json or pointing config at this file, then restart OpenCR."
  },
  "rules": [
    {
      "matchingType": "probabilistic",
      "fields": {
        "pmrsid": {
          "algorithm": "exact",
          "mValue": 0.99,
          "uValue": 1e-05,
          "fhirpath": "identifier.where(system='http://pmrs.gov.kh/patientid').value",
          "null_handling": "moderate",
          "null_handling_both": "moderate",
          "espath": "pmrsid"
        },
        "given": {
          "algorithm": "jaro-winkler-similarity",
          "threshold": 0.75,
          "mValue": 0.9172,
          "uValue": 0.003628,
          "fhirpath": "name.where(use='official').given",
          "null_handling": "moderate",
          "null_handling_both": "moderate",
          "espath": "given"
        },
        "family": {
          "algorithm": "jaro-winkler-similarity",
          "threshold": 0.85,
          "mValue": 0.9346,
          "uValue": 0.001898,
          "fhirpath": "name.where(use='official').family",
          "null_handling": "moderate",
          "null_handling_both": "moderate",
          "espath": "family"
        },
        "given_alias": {
          "algorithm": "jaro-winkler-similarity",
          "threshold": 0.75,
          "mValue": 0.9,
          "uValue": 0.004,
          "fhirpath": "name.where(use='old').given",
          "null_handling": "moderate",
          "null_handling_both": "moderate",
          "espath": "given_alias"
        },
        "family_alias": {
          "algorithm": "jaro-winkler-similarity",
          "threshold": 0.85,
          "mValue": 0.9,
          "uValue": 0.002,
          "fhirpath": "name.where(use='old').family",
          "null_handling": "moderate",
          "null_handling_both": "moderate",
          "espath": "family_alias"
        },
        "birthdate": {
          "algorithm": "exact",
          "mValue": 0.95,
          "uValue": 0.002,
          "fhirpath": "birthDate",
          "null_handling": "moderate",
          "null_handling_both": "moderate",
          "espath": "birthDate"
        },
        "phone": {
          "algorithm": "exact",
          "mValue": 0.85,
          "uValue": 0.0005,
          "fhirpath": "telecom.where(system='phone').value",
          "null_handling": "moderate",
          "null_handling_both": "conservative",
          "espath": "phone"
        }
      },
      "potentialMatchThreshold": 100,
      "autoMatchThreshold": 110,
      "filters": {
        "gender": {
          "fhirpath": "gender",
          "espath": "gender"
        }
      }
    }
  ]
}
