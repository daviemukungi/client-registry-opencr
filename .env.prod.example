# Copy to .env in the repository root before starting the production stack:
#   cp .env.prod.example .env

# OpenCR image published on Docker Hub
OPENCR_IMAGE_TAG=20260625-4bea9e2

# OpenSearch image (phonetic + record-linkage plugins) published on Docker Hub
OPENSEARCH_IMAGE_TAG=20260625-4bea9e2

# Host port exposed for the OpenCR UI and API (internal services are not published)
OPENCR_PORT=3000

# PostgreSQL credentials for HAPI FHIR (also set matching values in config_production.json fhirServer)
POSTGRES_DB=hapi
POSTGRES_USER=hapi
POSTGRES_PASSWORD=change-me

# OpenSearch JVM heap; increase on servers with more RAM (see docs/admin/requirements.md)
OPENSEARCH_JAVA_OPTS=-Xms4g -Xmx4g
